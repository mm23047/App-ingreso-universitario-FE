{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "lanzarBrowserSync",
            "type": "shell",
            "command": "browser-sync start --server src -f \"**/*\" ./src/ --no-open",
            "presentation": {
                "reveal": "silent"
            },
            "isBackground": true,
            "problemMatcher": {}
        },

        {
            "label": "detenerBrowserSync",
            "type": "shell",
            "command": "echo ${input:terminate}",
            "problemMatcher": {}
        }
    ],
    "inputs": [
        {
            "id": "terminate",
            "type": "command",
            "command": "workbench.action.tasks.terminate",
            "args": "terminateAll"
        }
    ]
}